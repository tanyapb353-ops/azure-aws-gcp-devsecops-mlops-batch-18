        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-39" value="Hi Myself Shyam working with xyz company from last 8 years, Having total experience 17 years out of which I am working&amp;nbsp;in devsecops&amp;nbsp;from last 8 years." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
