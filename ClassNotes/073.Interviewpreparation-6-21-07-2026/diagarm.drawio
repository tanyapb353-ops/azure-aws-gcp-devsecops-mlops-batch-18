        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-90" value="&lt;b&gt;What is difference between platform / landing zone subscription?&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1952.6299999999999" y="16570" width="665.99" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-91" value="Platform = Shared Services&lt;br&gt;Landing Zone = Actual Workload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1954.4099999999996" y="16600" width="663.42" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-92" value="&lt;b&gt;Explain Hub and Spoke Architecture?&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1954.4099999999999" y="16670" width="665.99" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-93" value="Recommended Network Architecture in crreation of landing zone" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1957.1899999999998" y="16700" width="663.42" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-94" value="Where central hub hosts shared services like Hub Vnet, Firewal, VPN gateway etc..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1957.1899999999998" y="16730" width="663.42" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-95" value="And multiple spoke vnets hosts application workload connected to hub using vnet peering" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1958.1199999999997" y="16760" width="663.42" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-96" value="&lt;b&gt;What are the best practices of creating the landing zone?&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1958.1199999999997" y="16920" width="665.99" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-97" value="Hub Vnet that is central layer contains shared and critical services like azure firewall, vpn gw, express route, dns, bastion" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1957.1899999999998" y="16790" width="663.42" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-98" value="Spoke Vnet that is called workload layer, Each spoke usually, contains one application infrastructure requirements resources like VM, VMss, ACI, App Services Etc... And there is no direct internet exposure to the spoke workloads." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1957.3999999999999" y="16820" width="663.42" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-99" value="1. Always spoke to spoke communication is not done directly, it goes via hub firwall with UDR integrated." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1958.1199999999997" y="16950" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-100" value="2. Always access paas services in the spoke network using private endpoints" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1958.1199999999997" y="16980" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-101" value="3. if possible, deploy architecture with multi region design" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1959.3999999999999" y="17010" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-102" value="&lt;b&gt;Advantages of Hub and Spoke&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1953.12" y="17090" width="676.88" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-103" value="Cost Optimization as shared services reduces duplication" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1954.76" y="17120" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-104" value="Single firewall for all workloads" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1954.76" y="17150" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-105" value="Centralised Security" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1955.25" y="17180" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-106" value="Scalability" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1954.76" y="17210" width="670.14" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fHLI1QGB96O2srPNdz7D-108" value="Isolation" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1954.76" y="17240" width="670.14" height="30" as="geometry" />
        </mxCell>
