        <mxCell id="vOCS-h0Zns1alFFI2X5f-37" value="&lt;b&gt;Hacker&lt;/b&gt;" style="shape=mxgraph.signs.sports.hiker;html=1;pointerEvents=1;fillColor=#f8cecc;strokeColor=#b85450;verticalLabelPosition=bottom;verticalAlign=top;align=center;" parent="1" vertex="1">
          <mxGeometry x="2527.46" y="10330" width="25.07" height="39" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-39" value="www.dhondhu.com" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="2533.38" y="10200" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-59" value="So since our application is a monolithic 3 tier application, We are deploying frontend and backend on vms and for database we are using paas services...&lt;br&gt;&lt;br&gt;We have designed the landing zone in such a way that the entrypoint of our application is application gateway where we have enabled WAF and SSL certs for security, behind this app gw, we have 2 vms on which frontend app is running,&lt;br&gt;Behind that we have a internal loadbalancer that is loadbalancing between the 2 backend vms..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="1498.33" y="10092.5" width="640" height="90" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-60" value="For. Database we are using a SQL Server that is a PAAS service so we do not need to manage the high availibilty of the database as its managed by azure." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=0" parent="1" vertex="1">
          <mxGeometry x="1497.77" y="10182.5" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-62" value="To securely ssh to the vms, we are using azure bastion and for storing secret we have a azure key vault." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="1497.77" y="10212.5" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-63" value="Landing Zone Explanation" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1ba1e2;strokeColor=#006EAF;fontColor=#ffffff;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="1498.8899999999999" y="10062.5" width="639.44" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-64" value="Terraform Setup" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1ba1e2;strokeColor=#006EAF;fontColor=#ffffff;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="1499.4499999999998" y="10272.5" width="639.44" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-65" value="For all the azure resources that we have in our landing zone, we have created child modules for each like we have a child module for vm, app gw, key vault etc...&amp;nbsp; in the child modules we use foreach, map, dynamic blocks etc.." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="1499.1699999999998" y="10302.5" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="vOCS-h0Zns1alFFI2X5f-66" value="Since we have 3 &lt;b&gt;environments &lt;/b&gt;of this applicaiton, Dev, QA and Prod" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=0" parent="1" vertex="1">
          <mxGeometry x="1500" y="10332.5" width="640" height="30" as="geometry" />
        </mxCell>
