        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-75" value="Refinery &lt;br&gt;Operator" style="image;aspect=fixed;perimeter=ellipsePerimeter;html=1;align=center;shadow=0;dashed=0;spacingTop=3;image=img/lib/active_directory/user.svg;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="1051.04" y="3800" width="22.2" height="60" as="geometry" />
        </mxCell>
        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-76" value="Hi, I am dhondhu, I am doing internship in DevOps Insiders from last 1 year where I am working on a very interesting use case for a UK based Client who is having multiple refineries within UK where our team is developing an application for refinery Operator." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="724.44" y="3930" width="529.49" height="50" as="geometry" />
        </mxCell>
        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-78" value="400 Motor" style="verticalLabelPosition=bottom;dashed=0;shadow=0;html=1;align=center;verticalAlign=top;shape=mxgraph.cabinets.motor_cb_125_400a;" parent="1" vertex="1">
          <mxGeometry x="937.7" y="3850.2" width="18.33" height="30" as="geometry" />
        </mxCell>
        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-79" value="So the problem is there are a lot of motors in one refinery and monitroring them continously is very difficult for the refinery operator man. So for that out team is developing a Industrial IOT based monitoring system where all the data from the motors is ingested in the application." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="724.44" y="3980" width="529.49" height="50" as="geometry" />
        </mxCell>
        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-80" value="and our application creates dashboard and send alerts on mobile in case of any threshold limit crossed..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="724.44" y="4030" width="529.49" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-81" value="So For this application, there are around 50 developers from which 10 frontend, 12 backend, around 5 database engineers." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="724.44" y="4091" width="529.49" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xmx8Y5nSZ1Oc5vyaJ7Zq-82" value="In this project my role as a devsecops engineer to design the &lt;b&gt;deployment architecture&lt;/b&gt; and the &lt;b&gt;cicd pipelines&lt;/b&gt; for the complete 3 tier application..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="725.21" y="4131" width="529.49" height="40" as="geometry" />
        </mxCell>
